NODE_ENV=development
PORT=3000
HOST=0.0.0.0
TRUST_PROXY_HOPS=0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inrota

# Gere segredos aleatórios diferentes, com pelo menos 32 caracteres.
JWT_SECRET=troque-por-um-segredo-aleatorio-com-32-caracteres

# Client ID do tipo "Aplicativo da Web", usado pelo Credential Manager Android.
GOOGLE_WEB_CLIENT_ID=
REQUIRE_GMAIL_DOMAIN=true

# Dados publicados na Play Console.
ANDROID_PACKAGE_NAME=com.inrota.app
ANDROID_CERT_SHA256=
PLAY_INTEGRITY_ENABLED=false
PLAY_REQUIRE_LICENSED=false
GOOGLE_APPLICATION_CREDENTIALS=

# RevenueCat: use um segredo aleatorio no header Authorization do webhook.
REVENUECAT_WEBHOOK_AUTH_TOKEN=
REVENUECAT_SECRET_API_KEY=
REVENUECAT_ENTITLEMENT_ID=pro

ACCESS_TOKEN_TTL_SECONDS=900
REGISTRATION_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
