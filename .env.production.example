NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Quantidade de proxies entre a internet e esta API. Use 1 para um proxy
# reverso comum e confirme o valor com o provedor da hospedagem.
TRUST_PROXY_HOPS=1

# PostgreSQL gerenciado com TLS conforme a exigencia do provedor.
DATABASE_URL=postgresql://usuario:senha@host:5432/inrota?sslmode=require

# Gere um valor aleatorio exclusivo, com no minimo 32 caracteres.
JWT_SECRET=

# Client ID OAuth do tipo "Aplicativo da Web".
GOOGLE_WEB_CLIENT_ID=
REQUIRE_GMAIL_DOMAIN=true

ANDROID_PACKAGE_NAME=com.inrota.app
ANDROID_CERT_SHA256=
PLAY_INTEGRITY_ENABLED=true
PLAY_REQUIRE_LICENSED=true

# Caminho do JSON somente quando a hospedagem nao fornecer credenciais por
# identidade da carga de trabalho.
GOOGLE_APPLICATION_CREDENTIALS=

REVENUECAT_WEBHOOK_AUTH_TOKEN=
REVENUECAT_SECRET_API_KEY=
REVENUECAT_ENTITLEMENT_ID=pro

ACCESS_TOKEN_TTL_SECONDS=900
REGISTRATION_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
